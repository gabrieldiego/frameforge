# Generic Xilinx 7-series/Zynq-7000 synthesis target.
# Override FPGA_PART, FPGA_FAMILY, and DEFAULT_CLOCK_MHZ from the environment
# or with a custom board .env file when targeting a specific board.
BOARD_NAME=generic-xc7
FPGA_VENDOR=xilinx
FPGA_FAMILY=xc7
FPGA_PART=xc7z010clg400-1
DEFAULT_CLOCK_MHZ=50

